# Optional initial directory Pi can read and modify. Defaults to where the app is launched.
# PI_WORKSPACE=/absolute/path/to/a/project

# The Pi executable. Keep this as pi when it is installed globally.
PI_COMMAND=pi

# The web controller listens locally by default.
PI_WEB_HOST=127.0.0.1
PI_WEB_PORT=8787

# Required when PI_WEB_HOST is not a loopback address. Recommended everywhere.
PI_WEB_TOKEN=replace-with-a-long-random-token

# Optional Pi launch settings.
# PI_PROVIDER=anthropic
# PI_MODEL=claude-sonnet-4-20250514
# PI_SESSION_DIR=/absolute/path/to/sessions
# PI_NO_SESSION=false
# PI_AUTO_START=true

# Optional exact browser origin for WebSocket requests.
# PI_WEB_ORIGIN=https://pi.example.com
